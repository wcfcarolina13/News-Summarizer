# Gemini API Key (Get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_key_here

# Google Sheets (optional) — place google_credentials.json in this directory
# See README.md for service account setup instructions

# API Cost Controls (optional — override api_usage.json limits)
# These survive Render redeploys where api_usage.json is ephemeral.
# API_DAILY_MAX_CALLS=100       # Max Gemini API calls per day
# API_MONTHLY_MAX_CALLS=2000    # Max Gemini API calls per month
# API_MONTHLY_BUDGET=0.50       # Dollar cap per month (stops all calls when hit)
# API_LIMITS_ENABLED=true       # Enable/disable limit enforcement
# API_COOLDOWN_ENABLED=true     # Stop API calls when budget is exhausted
